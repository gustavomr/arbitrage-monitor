# Configurações da API Binance
BINANCE_API_KEY=sua_api_key_aqui
BINANCE_API_SECRET=seu_api_secret_aqui
RECIPIENT_ADDRESS=0x_seu_endereco_polygon_aqui

# Valor em BRL para gastar (MÍNIMO: 10.00 para USDTBRL)
BRL_AMOUNT=10.00

# Modo simulação (true=simulação, false=real)
SIMULATION_MODE=true

# Configurações do Arbitrage Monitor
ONEINCH_API_KEY=xxx        # portal.1inch.dev (gratuito)
POLL_INTERVAL=45           # segundos entre polls (padrão 45)
TARGET_SPREAD=0.5          # % mínimo para alertar (padrão 0.5)
CAPITAL_AMOUNT=6000       # capital de entrada (padrão 6000)
CEX_SPREAD_COST=0.1        # custo de spread da CEX em % (padrão 0.1)

# Telegram Configuration
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
TELEGRAM_CHAT_ID=YOUR_CHAT_ID_HERE
TELEGRAM_ENABLED=true
TELEGRAM_PARSE_MODE=HTML

# IMPORTANTE:
# - USDTBRL exige valor mínimo de 10.00 BRL por ordem (MIN_NOTIONAL)
# - Preço válido: 4.30 - 6.50 BRL/USDT (PRICE_FILTER)
# - Quantidade mínima: 0.1 USDT (LOT_SIZE)
# - Use valores >= 10.00 para evitar rejeição da ordem
